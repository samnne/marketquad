{
  "expo": {
    "name": "MarketQuad",
    "slug": "marketquad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "scheme": "mqphone",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.samuelechefu.marketquad",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "MarketQuad accesses your photo library so you can select and upload images to your profile or listings. For example, you can choose a photo from your library to use as your profile picture or add product images to a listing.",
        "NSPhotoLibraryAddUsageDescription": "MarketQuad saves images to your photo library when you download photos from listings or your profile.",
        "NSCameraUsageDescription": "MarketQuad uses your camera so you can take and upload photos directly to your profile or listings."
      },
      "icon": {
        "light": "./assets/icons/ios-light.png"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.samuelechefu.marketquad"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Allow $(PRODUCT_NAME) to use your location"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/ios-light.png",
          "color": "#ffffff"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "marketquad"
        }
      ],
      "expo-localization",
      "expo-video",
      "@sentry/react-native",
      [
        "expo-image-picker",
        {
          "photosPermission": "MarketQuad accesses your photo library so you can select and upload images to your profile or listings. For example, you can choose a photo to use as your profile picture or add images to a listing.",
          "cameraPermission": "MarketQuad uses your camera so you can take and upload photos directly to your profile or listings.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f6fcf1b5-debb-4f21-966a-eaa9e1f94ce5"
      }
    },
    "owner": "samuelechefu",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f6fcf1b5-debb-4f21-966a-eaa9e1f94ce5"
    }
  }
}
